+
+  // Hooks (stubs for Node.js)
+  useEvent: () => {},
+  useEventListener: () => {},
+
+  // UUID
+  uuid: { v4: () => "00000000-0000-0000-0000-000000000000" },
+
+  // Platform
+  Platform: { OS: "ios" },
+
+  // Refs
+  useReleasingSharedObject,
+
+  // Legacy
+  NativeModulesProxy: {},
+  LegacyEventEmitter: class LegacyEventEmitter {},
+};
